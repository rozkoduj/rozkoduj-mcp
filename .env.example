# rozkoduj-mcp environment

# Transport: "stdio" (default, local) or "streamable-http" (remote / Cloud Run)
MCP_TRANSPORT=stdio

# Data API base URL + outbound-token audience (defaults shown)
# ROZKODUJ_API_URL=https://api.rozkoduj.com
# ROZKODUJ_API_AUDIENCE=https://api.rozkoduj.com

# Self-host only: your Rozkoduj API key (rzk_ + 40 hex). Used to authenticate
# to the data API when NOT running on Cloud Run; it authenticates as your
# subscription tier. On Cloud Run leave this unset - the service-identity
# token is used automatically. Never commit a real value.
# ROZKODUJ_API_KEY=rzk_0000000000000000000000000000000000000000
